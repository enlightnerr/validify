# --- Root ENV variables for Docker Compose ---
# These variables control the mapped ports on your local host

# The external port for the Node backend
BACKEND_PORT=5000

# The base URL the frontend should use to talk to the Node backend
# If deploying locally via docker compose, this shouldn't be docker internal name
# it should be localhost since the browser tries to hit it on your machine.
VITE_API_BASE_URL=http://localhost:5000
